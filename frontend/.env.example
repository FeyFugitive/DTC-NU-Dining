# Optional: Google Analytics (omit for local dev)
# VITE_GA_MEASUREMENT_ID=

# Optional: Firebase Auth — required only for sign-in / favorites persistence.
# Without these, the app still runs; Google sign-in is disabled.
# VITE_FIREBASE_APIKEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=   # required for dish photo uploads (Firebase Storage)
# VITE_FIREBASE_MESSAGE_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=
